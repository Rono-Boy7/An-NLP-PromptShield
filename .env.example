# promptshield/.env.example

PROMPTSHIELD_ENV=development
PROMPTSHIELD_LOG_LEVEL=INFO

# Local API settings
PROMPTSHIELD_API_HOST=127.0.0.1
PROMPTSHIELD_API_PORT=8000

# Dataset paths
PROMPTSHIELD_DATA_DIR=data
PROMPTSHIELD_RAW_DATA_DIR=data/raw
PROMPTSHIELD_PROCESSED_DATA_DIR=data/processed

# Model/artifact paths
PROMPTSHIELD_ARTIFACTS_DIR=artifacts
PROMPTSHIELD_MODELS_DIR=artifacts/models

# Optional future provider keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=